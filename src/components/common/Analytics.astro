---
import { ANALYTICS } from '~/config/site';

const googleAnalyticsId = ANALYTICS.vendors.googleAnalytics.id;
---

{
  googleAnalyticsId ? (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`} />
      <script is:inline define:vars={{ googleAnalyticsId }}>
        window.dataLayer = window.dataLayer || []; window.dataLayer.push(['js', new Date()]);
        window.dataLayer.push(['config', googleAnalyticsId]);
      </script>
    </>
  ) : null
}
