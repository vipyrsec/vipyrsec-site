---
export interface Props {
  label?: string;
  class?: string;
}

const {
  label = 'Toggle Menu',
  class:
    className = 'group inline-flex h-11 w-11 flex-col items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-slate-100 transition hover:border-white/20 hover:bg-white/[0.08]',
} = Astro.props;
---

<button type="button" class={className} aria-label={label} data-aw-toggle-menu>
  <span class="sr-only">{label}</span>
  <slot>
    <span
      aria-hidden="true"
      class="my-1 h-0.5 w-5 rounded-full bg-current opacity-90 transition duration-200 ease-transform group-[.expanded]:translate-y-2.5 group-[.expanded]:rotate-45"
    ></span>
    <span
      aria-hidden="true"
      class="my-1 h-0.5 w-5 rounded-full bg-current opacity-90 transition duration-200 ease-transform group-[.expanded]:opacity-0"
    ></span>
    <span
      aria-hidden="true"
      class="my-1 h-0.5 w-5 rounded-full bg-current opacity-90 transition duration-200 ease-transform group-[.expanded]:-translate-y-2.5 group-[.expanded]:-rotate-45"
    ></span>
  </slot>
</button>
