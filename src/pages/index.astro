---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import Button from '~/components/ui/Button.astro';
import SectionHeading from '~/components/site/SectionHeading.astro';
import { findLatestPosts } from '~/utils/blog';
import { getBlogPermalink, getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Home',
  ignoreTitleTemplate: true,
  description:
    'Vipyr Security operates public systems for package intake, malware scanning, package reporting, and supply chain research.',
};

const stats = [
  { title: 'Packages scanned', amount: '1.16M' },
  { title: 'Package takedowns', amount: '1322' },
  { title: 'Detection signatures', amount: '150+' },
  { title: 'Contributors', amount: '16' },
];

const heroSignals = ['Package feed intake', 'Distribution scanning', 'Package reporting'];

const operatingSequence = [
  { title: 'PyPI RSS loader', status: 'Queued' },
  { title: 'Mainframe job dispatch', status: 'Assigned' },
  { title: 'Client scan results', status: 'Returned' },
  { title: 'Reporter + analyst review', status: 'Actioned' },
];

const operatingStatusClasses = {
  Queued: 'text-sky-200 hero-status-glow-sky',
  Assigned: 'text-indigo-200 hero-status-glow-indigo',
  Returned: 'text-amber-200 hero-status-glow-amber',
  Actioned: 'text-emerald-200 hero-status-glow-emerald',
};

const capabilityCards = [
  {
    title: 'Observe package ecosystems',
    description:
      'Vipyr uses automated intake around package activity so new releases can be loaded into the Dragonfly workflow and reviewed before they disappear into the stream.',
    icon: 'tabler:radar-2',
  },
  {
    title: 'Investigate malicious artifacts',
    description:
      'Dragonfly clients request work from the API, download distributions, scan package files, and return results in a form that can be reviewed and acted on.',
    icon: 'tabler:binary-tree-2',
  },
  {
    title: 'Coordinate remediation',
    description:
      'Queue, reporting, and recent-activity flows exist across Dragonfly services so detections can move toward package reports and writeups.',
    icon: 'tabler:shield-check',
  },
];

const dragonflyProjects = [
  {
    title: 'Dragonfly Server',
    description:
      'Mainframe service responsible for job distribution, result intake, and the API surface behind package lookup, queue handling, and reporting flows.',
    href: 'https://github.com/vipyrsec/dragonfly-mainframe',
    icon: 'tabler:server-2',
  },
  {
    title: 'Dragonfly Client',
    description:
      'Rust compute node that authenticates, retrieves rule content, downloads package distributions, scans files, and sends package results back upstream.',
    href: 'https://github.com/vipyrsec/dragonfly-client-rs',
    icon: 'tabler:cpu',
  },
  {
    title: 'Dragonfly Bot',
    description:
      'Discord-facing triage surface that keeps community review close to the operating workflow instead of isolating it in a separate channel.',
    href: 'https://github.com/vipyrsec/bot',
    icon: 'tabler:brand-discord',
  },
];

const supportingSystems = [
  {
    title: 'Dragonfly Loader',
    description: 'Automated job for loading newly observed PyPI releases into the mainframe.',
    href: 'https://github.com/vipyrsec/dragonfly-loader',
  },
  {
    title: 'Dragonfly Reporter',
    description: 'Reporting microservice used to submit malicious package reports back to PyPI.',
    href: 'https://github.com/vipyrsec/dragonfly-reporter',
  },
  {
    title: 'Snakehook Runner',
    description:
      'Public Python package triage sandbox with constrained execution and webhook reporting for focused package review.',
    href: 'https://github.com/import-pandas-as-numpy/snakehook-runner',
  },
];

const posts = await findLatestPosts({ count: 3 });
const [featuredPost, ...recentPosts] = posts;
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' }).format(date);
---

<Layout metadata={metadata}>
  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-7xl px-4 pb-18 pt-10 sm:px-6 md:pb-24 md:pt-16">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(360px,0.85fr)] lg:items-center">
        <div class="max-w-3xl">
          <div
            class="mb-5 inline-flex rounded-full border border-sky-400/20 bg-sky-400/10 px-3 py-1 text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-sky-200"
          >
            Open source supply chain defense
          </div>
          <h1 class="max-w-4xl text-5xl font-semibold tracking-[-0.06em] text-white sm:text-6xl lg:text-7xl">
            Bring calm, modern signal to package security.
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-400 sm:text-xl">
            Vipyr runs public systems for package intake, distributed scanning, malicious package reporting, and supply
            chain research so suspicious releases can move from feed activity to actionable review.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <Button variant="primary" href="#capabilities" text="Explore capabilities" icon="tabler:arrow-down-right" />
            <Button variant="secondary" href={getBlogPermalink()} text="Read latest research" />
          </div>
          <div class="mt-10 flex flex-wrap gap-3 text-sm text-slate-400">
            {
              heroSignals.map((signal) => (
                <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-4 py-2.5">
                  <span class="h-1.5 w-1.5 rounded-full bg-sky-300/80" />
                  <span>{signal}</span>
                </div>
              ))
            }
          </div>
        </div>

        <div
          class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-[var(--vipyr-bg-elevated)] p-6 shadow-[var(--vipyr-shadow)] backdrop-blur"
        >
          <div
            class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sky-300/35 to-transparent"
            aria-hidden="true"
          >
          </div>
          <div class="flex items-center justify-between">
            <div class="text-[0.72rem] font-semibold uppercase tracking-[0.3em] text-slate-500">
              Live operating view
            </div>
            <div
              class="inline-flex items-center gap-2 rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-emerald-300"
            >
              <span class="h-2 w-2 rounded-full bg-emerald-300 hero-presence-dot"></span>
              <span>Active</span>
            </div>
          </div>
          <h2 class="mt-5 text-3xl font-semibold tracking-[-0.05em] text-white">Detection to takedown</h2>

          <div class="mt-6 grid gap-4 md:grid-cols-2">
            <div class="rounded-[1.5rem] border border-white/8 bg-[var(--vipyr-bg-panel)] p-5">
              <div class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-slate-500">Coverage</div>
              <div class="mt-3 text-4xl font-semibold tracking-[-0.05em] text-white">24/7</div>
              <p class="mt-3 text-sm leading-7 text-slate-400">
                Continuous package scanning and incident review for emerging supply chain abuse.
              </p>
            </div>
            <div class="hero-response-card rounded-[1.5rem] border border-white/8 bg-[var(--vipyr-bg-panel)] p-5">
              <div class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-slate-500">Response</div>
              <div class="mt-3 text-4xl font-semibold tracking-[-0.05em] text-white">10m</div>
              <p class="mt-3 text-sm leading-7 text-slate-400">
                Malicious packages often sit undetected for days or months. Confirmed packages we report are typically
                acted on in about 10 minutes.
              </p>
            </div>
          </div>

          <div class="mt-4 rounded-[1.5rem] border border-white/8 bg-[var(--vipyr-bg-panel)] p-5">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-slate-500">
                Operating sequence
              </div>
              <div
                class="rounded-full border border-sky-400/20 bg-sky-400/10 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-sky-200"
              >
                Structured
              </div>
            </div>
            <p class="mt-4 text-lg font-semibold text-white">Observe, triage, remediate, publish</p>
            <p class="mt-2 text-sm leading-7 text-slate-500">A representative workflow, not a literal live feed.</p>
            <div class="mt-5 space-y-3">
              {
                operatingSequence.map((step, index) => (
                  <div
                    class="hero-sequence-row flex items-center justify-between rounded-full border border-white/6 bg-[#081427] px-4 py-3 text-sm"
                    style={`--hero-sequence-delay:${index * 1.1}s`}
                  >
                    <span class="flex items-center gap-3 font-medium text-slate-200">
                      <span class="h-2 w-2 rounded-full bg-sky-300/70 hero-sequence-dot" />
                      <span>{step.title}</span>
                    </span>
                    <span
                      class:list={[
                        'text-[0.68rem] font-semibold uppercase tracking-[0.24em] transition',
                        operatingStatusClasses[step.status as keyof typeof operatingStatusClasses] ?? 'text-slate-300',
                      ]}
                    >
                      {step.status}
                    </span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="capabilities" class="mx-auto max-w-7xl px-4 py-18 sm:px-6 md:py-24">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
      <SectionHeading
        eyebrow="Why Vipyr exists"
        title="Modern package security needs both automation and human judgment."
        description="Package ecosystems move fast, but useful security work still depends on understandable workflows. Vipyr couples automated intake and scanning systems with review surfaces, reporting paths, and public writeups."
      />
      <div class="grid gap-4">
        {
          capabilityCards.map((item) => (
            <div class="rounded-[1.75rem] border border-white/10 bg-white/[0.03] p-6 shadow-[var(--vipyr-shadow)]">
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-sky-400/20 bg-sky-400/10 text-sky-200">
                  <Icon name={item.icon} class="h-6 w-6" />
                </div>
                <div>
                  <h2 class="text-xl font-semibold text-white">{item.title}</h2>
                  <p class="mt-3 text-base leading-8 text-slate-400">{item.description}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-18 sm:px-6 md:py-24">
    <SectionHeading
      title="Operational output that reads like a security organization, not a landing-page template."
      description="Measured evidence matters more than hype. Vipyr’s footprint spans sustained package intake, malware scanning, package reporting, community review, and published technical analysis."
      align="center"
    />
    <div class="mt-10 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      {
        stats.map((stat) => (
          <div class="rounded-[1.75rem] border border-white/10 bg-[var(--vipyr-bg-panel)] p-6 text-center shadow-[var(--vipyr-shadow)]">
            <div class="text-4xl font-semibold tracking-[-0.05em] text-white md:text-5xl">{stat.amount}</div>
            <div class="mt-3 text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-slate-500">{stat.title}</div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-18 sm:px-6 md:py-24">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-start">
      <SectionHeading
        eyebrow="Dragonfly"
        title="A distributed malware analysis workflow built for package ecosystem response."
        description="Dragonfly is the operational backbone behind Vipyr’s package analysis workflows. It spans automated intake, job distribution, compute-node scanning, reporting services, and authenticated review surfaces."
      />
      <div class="grid gap-4">
        {
          dragonflyProjects.map((project) => (
            <div class="rounded-[1.75rem] border border-white/10 bg-[var(--vipyr-bg-panel)] p-6 shadow-[var(--vipyr-shadow)]">
              <div class="flex items-start justify-between gap-4">
                <div class="flex gap-4">
                  <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.04] text-sky-200">
                    <Icon name={project.icon} class="h-6 w-6" />
                  </div>
                  <div>
                    <h2 class="text-xl font-semibold text-white">{project.title}</h2>
                    <p class="mt-3 text-base leading-8 text-slate-400">{project.description}</p>
                  </div>
                </div>
                <a
                  href={project.href}
                  class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-slate-300 transition hover:border-white/20 hover:bg-white/[0.08] hover:text-white"
                  aria-label={`View source for ${project.title}`}
                >
                  <Icon name="tabler:arrow-up-right" class="h-5 w-5" />
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-18 sm:px-6 md:py-24">
    <SectionHeading
      title="The workflow extends beyond three repos."
      description="Vipyr’s production-facing systems include release intake, reporting services, authenticated review surfaces, and focused triage sandboxes around the core Dragonfly stack."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {
        supportingSystems.map((system) => (
          <a
            href={system.href}
            class="rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-5 shadow-[var(--vipyr-shadow)] transition hover:border-white/20 hover:bg-white/[0.05]"
          >
            <h2 class="text-lg font-semibold text-white">{system.title}</h2>
            <p class="mt-3 text-sm leading-7 text-slate-400">{system.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-18 sm:px-6 md:py-24">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionHeading
        eyebrow="Research"
        title="Published threat analysis is part of the service, not an afterthought."
        description="Vipyr’s research archive explains real package abuse, reverse engineering work, and ecosystem issues observed through the organization’s operating systems."
      />
      <Button variant="secondary" href={getBlogPermalink()} text="Browse all research" />
    </div>

    {
      featuredPost && (
        <div class="mt-10 grid gap-4 lg:grid-cols-[minmax(0,1.15fr)_minmax(300px,0.85fr)]">
          <a
            href={getPermalink(featuredPost.permalink, 'post')}
            class="rounded-[2rem] border border-white/10 bg-[var(--vipyr-bg-panel)] p-8 shadow-[var(--vipyr-shadow)] transition hover:border-white/20 hover:bg-[var(--vipyr-bg-panel-strong)]"
          >
            <div class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-slate-500">
              Featured analysis {featuredPost.category ? `• ${featuredPost.category.title}` : ''}
            </div>
            <h2 class="mt-5 max-w-3xl text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
              {featuredPost.title}
            </h2>
            <p class="mt-5 max-w-2xl text-base leading-8 text-slate-400">{featuredPost.excerpt}</p>
            <div class="mt-8 flex items-center gap-4 text-sm text-slate-500">
              <span>{formatDate(featuredPost.publishDate)}</span>
              {featuredPost.readingTime && <span>{featuredPost.readingTime} min read</span>}
            </div>
          </a>

          <div class="grid gap-4">
            {recentPosts.map((post) => (
              <a
                href={getPermalink(post.permalink, 'post')}
                class="rounded-[1.75rem] border border-white/10 bg-white/[0.03] p-6 shadow-[var(--vipyr-shadow)] transition hover:border-white/20 hover:bg-white/[0.05]"
              >
                <div class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-slate-500">
                  {post.category?.title ?? 'Research'}
                </div>
                <h3 class="mt-4 text-xl font-semibold text-white">{post.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-400">{post.excerpt}</p>
                <div class="mt-5 text-sm text-slate-500">{formatDate(post.publishDate)}</div>
              </a>
            ))}
          </div>
        </div>
      )
    }
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-12 pt-18 sm:px-6 md:pb-20 md:pt-24">
    <div
      class="rounded-[2rem] border border-white/10 bg-[linear-gradient(135deg,rgba(21,38,79,0.94),rgba(8,16,34,0.94))] p-8 shadow-[var(--vipyr-shadow)] md:p-10"
    >
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
        <div>
          <h2 class="text-3xl font-semibold tracking-[-0.04em] text-white md:text-4xl">
            Explore the research, inspect the tooling, and stay close to the signal.
          </h2>
          <p class="mt-4 max-w-2xl text-base leading-8 text-slate-400">
            Follow the workflow from technical writeups to the systems behind them. The same public repos that support
            intake, scanning, queue handling, reporting, and focused triage also make the organization easier to
            understand from the outside.
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
          <Button variant="primary" href={getBlogPermalink()} text="Read research" />
          <Button variant="secondary" href={getPermalink('/projects')} text="Review projects" />
        </div>
      </div>
    </div>
  </section>

  <style is:inline>
    @keyframes heroPresencePulse {
      0%,
      100% {
        opacity: 0.55;
        transform: scale(1);
      }
      50% {
        opacity: 1;
        transform: scale(1.12);
      }
    }

    @keyframes heroSequencePulse {
      0%,
      100% {
        border-color: rgb(255 255 255 / 0.06);
        background: rgb(8 20 39);
        box-shadow:
          inset 0 1px 0 rgb(255 255 255 / 0.02),
          0 0 0 rgb(70 153 255 / 0);
        transform: translateX(0) scale(1);
      }
      50% {
        border-color: rgb(102 160 255 / 0.18);
        background: rgb(10 25 48);
        box-shadow:
          inset 0 1px 0 rgb(255 255 255 / 0.04),
          0 10px 24px rgb(12 31 64 / 0.22),
          0 0 24px rgb(70 153 255 / 0.1);
        transform: translateX(4px) scale(1.02);
      }
    }

    @keyframes heroCardGlow {
      0%,
      100% {
        box-shadow:
          inset 0 1px 0 rgb(255 255 255 / 0.03),
          0 0 0 rgb(70 153 255 / 0);
      }
      50% {
        box-shadow:
          inset 0 1px 0 rgb(255 255 255 / 0.06),
          0 0 28px rgb(70 153 255 / 0.12);
      }
    }

    .hero-presence-dot {
      animation: heroPresencePulse 2.2s ease-in-out infinite;
    }

    .hero-sequence-row {
      animation: heroSequencePulse 4.8s ease-in-out infinite;
      animation-delay: var(--hero-sequence-delay, 0s);
      transform-origin: left center;
      will-change: transform, box-shadow, border-color, background-color;
    }

    .hero-sequence-dot {
      animation: heroPresencePulse 2.2s ease-in-out infinite;
      animation-delay: var(--hero-sequence-delay, 0s);
    }

    .hero-response-card {
      animation: heroCardGlow 3.4s ease-in-out infinite;
    }

    .hero-status-glow-sky {
      text-shadow: 0 0 16px rgb(86 188 255 / 0.26);
    }

    .hero-status-glow-indigo {
      text-shadow: 0 0 16px rgb(165 180 252 / 0.24);
    }

    .hero-status-glow-amber {
      text-shadow: 0 0 16px rgb(251 191 36 / 0.22);
    }

    .hero-status-glow-emerald {
      text-shadow: 0 0 16px rgb(52 211 153 / 0.24);
    }
  </style>
</Layout>
