---
export interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { eyebrow, title, description, align = 'left', class: className = '' } = Astro.props;
const isCentered = align === 'center';
---

<div class:list={[className, isCentered ? 'mx-auto max-w-3xl text-center' : 'max-w-3xl']}>
  {
    eyebrow && (
      <div
        class:list={[
          'mb-4 inline-flex rounded-full border border-sky-400/20 bg-sky-400/10 px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.28em] text-sky-200',
          isCentered ? 'mx-auto' : '',
        ]}
      >
        {eyebrow}
      </div>
    )
  }
  <h2 class="text-3xl font-semibold tracking-[-0.04em] text-white sm:text-4xl md:text-5xl">{title}</h2>
  {
    description && (
      <p
        class:list={[
          'mt-5 text-base leading-8 text-slate-400 sm:text-lg',
          isCentered ? 'mx-auto max-w-2xl' : 'max-w-2xl',
        ]}
      >
        {description}
      </p>
    )
  }
</div>
