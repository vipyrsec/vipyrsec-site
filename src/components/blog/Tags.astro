---
import { getPermalink } from '~/utils/permalinks';

import { APP_BLOG } from '~/config/site';
import type { Post } from '~/types';

export interface Props {
  tags: Post['tags'];
  class?: string;
  title?: string | undefined;
  isCategory?: boolean;
}

const { tags, class: className = 'text-sm', title = undefined, isCategory = false } = Astro.props;
---

{
  tags && Array.isArray(tags) && (
    <>
      {title !== undefined && (
        <span class="align-super font-normal text-slate-400 underline decoration-2 underline-offset-4">{title}</span>
      )}
      <ul class={`flex flex-wrap gap-2 ${className}`}>
        {tags.map((tag) => (
          <li class="inline-block rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-sm font-medium text-slate-300">
            {!APP_BLOG?.tag?.isEnabled ? (
              tag.title
            ) : (
              <a href={getPermalink(tag.slug, isCategory ? 'category' : 'tag')} class="transition hover:text-white">
                {tag.title}
              </a>
            )}
          </li>
        ))}
      </ul>
    </>
  )
}
