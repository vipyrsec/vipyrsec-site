---
import { UI } from '~/config/site';

const defaultTheme = UI.theme || 'system';
---

<style is:inline>
  html[data-aw-theme-transition='false'] *,
  html[data-aw-theme-transition='false'] *::before,
  html[data-aw-theme-transition='false'] *::after {
    transition: none !important;
  }
</style>

<script is:inline define:vars={{ defaultTheme }}>
  (() => {
    const storageKey = 'theme';
    const root = document.documentElement;
    const systemTheme = window.matchMedia('(prefers-color-scheme: dark)');
    const isLockedTheme = defaultTheme.endsWith(':only');
    const fallbackTheme = defaultTheme.replace(':only', '');

    const syncThemeControls = (theme) => {
      document.querySelectorAll('[data-aw-toggle-color-scheme]').forEach((button) => {
        button.setAttribute('aria-pressed', String(theme === 'dark'));
      });
    };

    const resolveTheme = () => {
      if (isLockedTheme) {
        return fallbackTheme;
      }

      const storedTheme = localStorage.getItem(storageKey);
      if (storedTheme === 'light' || storedTheme === 'dark') {
        return storedTheme;
      }

      if (defaultTheme !== 'system') {
        return fallbackTheme;
      }

      return systemTheme.matches ? 'dark' : 'light';
    };

    const applyTheme = (theme, { persist = false } = {}) => {
      root.dataset.awThemeTransition = 'false';
      root.classList.toggle('dark', theme === 'dark');
      root.style.colorScheme = theme;
      root.dataset.theme = theme;

      if (persist && !isLockedTheme) {
        localStorage.setItem(storageKey, theme);
      }

      syncThemeControls(theme);

      requestAnimationFrame(() => {
        root.removeAttribute('data-aw-theme-transition');
      });

      return theme;
    };

    const setTheme = (theme) => {
      if (isLockedTheme) {
        return;
      }

      applyTheme(theme, { persist: true });
    };

    const resetTheme = () => {
      if (isLockedTheme) {
        return;
      }

      localStorage.removeItem(storageKey);
      applyTheme(resolveTheme());
    };

    window.__vipyrTheme = {
      applyTheme,
      defaultTheme,
      isLockedTheme,
      resetTheme,
      resolveTheme,
      setTheme,
      syncThemeControls,
    };

    applyTheme(resolveTheme());

    systemTheme.addEventListener('change', () => {
      if (!isLockedTheme && defaultTheme === 'system' && !localStorage.getItem(storageKey)) {
        applyTheme(resolveTheme());
      }
    });
  })();
</script>
