---
import { APP_BLOG } from '~/config/site';
import type { Post } from '~/types';

import Image from '~/components/common/Image.astro';

import { findImage } from '~/utils/images';
import { getPermalink } from '~/utils/permalinks';

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const image = await findImage(post.image);

const link = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';
---

<article
  class="intersect-once intersect-quarter rounded-[1.75rem] border border-white/10 bg-[var(--vipyr-bg-panel)] p-5 shadow-[var(--vipyr-shadow)] transition hover:border-white/20 motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
>
  <div class="relative mb-5 overflow-hidden rounded-[1.25rem] border border-white/8 bg-slate-800/80">
    {
      image &&
        (link ? (
          <a href={link}>
            <Image
              src={image}
              class="w-full bg-gray-400 dark:bg-slate-700"
              widths={[400, 900]}
              width={400}
              sizes="(max-width: 900px) 400px, 900px"
              alt={post.title}
              aspectRatio="16:9"
              layout="cover"
              loading="lazy"
              decoding="async"
            />
          </a>
        ) : (
          <Image
            src={image}
            class="w-full bg-gray-400 dark:bg-slate-700"
            widths={[400, 900]}
            width={400}
            sizes="(max-width: 900px) 400px, 900px"
            alt={post.title}
            aspectRatio="16:9"
            layout="cover"
            loading="lazy"
            decoding="async"
          />
        ))
    }
  </div>

  <h3 class="mb-3 text-xl font-semibold leading-tight text-white sm:text-2xl">
    {
      link ? (
        <a class="inline-block transition ease-in duration-200 hover:text-sky-200" href={link}>
          {post.title}
        </a>
      ) : (
        post.title
      )
    }
  </h3>

  <p class="text-base leading-7 text-slate-400">{post.excerpt}</p>
</article>
