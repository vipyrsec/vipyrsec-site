---
import { APP_BLOG } from '~/config/site';
import { getRelatedPosts } from '~/utils/blog';
import type { Post } from '~/types';
import { getBlogPermalink, getPermalink } from '~/utils/permalinks';
import { findImage } from '~/utils/images';
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';

export interface Props {
  post: Post;
}

const { post } = Astro.props;

const relatedPosts = post.tags ? await getRelatedPosts(post, 4) : [];
---

{
  APP_BLOG.isRelatedPostsEnabled ? (
    relatedPosts.length > 0 ? (
      <section class="mx-auto max-w-7xl px-4 pb-16 pt-4 sm:px-6 md:pb-24">
        <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <h2 class="text-3xl font-semibold tracking-[-0.04em] text-white">Continue through adjacent analysis.</h2>
          <Button variant="secondary" href={getBlogPermalink()} text="Browse all research" />
        </div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {await Promise.all(
            relatedPosts.map(async (relatedPost) => {
              const image = await findImage(relatedPost.image);

              return (
                <a
                  href={getPermalink(relatedPost.permalink, 'post')}
                  class="rounded-[1.75rem] border border-white/10 bg-[var(--vipyr-bg-panel)] p-5 shadow-[var(--vipyr-shadow)] transition hover:border-white/20"
                >
                  {image && (
                    <div class="mb-5 overflow-hidden rounded-[1.25rem] border border-white/8">
                      <Image
                        src={image}
                        class="w-full"
                        widths={[400, 900]}
                        width={400}
                        sizes="(max-width: 900px) 400px, 900px"
                        alt={relatedPost.title}
                        aspectRatio="16:9"
                        layout="cover"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )}
                  <div class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-slate-500">
                    {relatedPost.category?.title ?? 'Research'}
                  </div>
                  <h3 class="mt-3 text-xl font-semibold text-white">{relatedPost.title}</h3>
                  <p class="mt-3 text-sm leading-7 text-slate-400">{relatedPost.excerpt}</p>
                </a>
              );
            })
          )}
        </div>
      </section>
    ) : null
  ) : null
}
