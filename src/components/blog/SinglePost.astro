---
import { Icon } from 'astro-icon/components';

import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';
import SocialShare from '~/components/common/SocialShare.astro';

import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;
---

<section class="py-8 sm:py-16 lg:py-20 mx-auto">
  <article data-article-root>
    <header class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class:list={['gap-10', post.image ? 'lg:grid lg:grid-cols-[minmax(0,1fr)_340px] lg:items-start' : '']}>
          <div class="min-w-0 max-w-3xl">
            <div
              class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-slate-500"
            >
              {
                post.category && (
                  <>
                    <a class="transition hover:text-slate-300" href={getPermalink(post.category.slug, 'category')}>
                      {post.category.title}
                    </a>
                    <span aria-hidden="true" class="h-1 w-1 rounded-full bg-slate-600" />
                  </>
                )
              }
              <span class="inline-flex items-center gap-2">
                <Icon name="tabler:clock" class="h-4 w-4" />
                <time datetime={String(post.publishDate)}>{getFormattedDate(post.publishDate)}</time>
              </span>
              {
                post.readingTime && (
                  <>
                    <span aria-hidden="true" class="h-1 w-1 rounded-full bg-slate-600" />
                    <span>{post.readingTime} min read</span>
                  </>
                )
              }
              {post.author && <span>{post.author}</span>}
            </div>

            <h1
              class="mt-4 max-w-4xl text-3xl font-semibold tracking-[-0.05em] text-white sm:text-4xl lg:text-[3.15rem]"
            >
              {post.title}
            </h1>
            <p class="mt-4 max-w-3xl text-base leading-7 text-slate-400 sm:text-[1.05rem] sm:leading-8">
              {post.excerpt}
            </p>

            <div
              class="mt-6 flex flex-col gap-4 border-t border-white/10 pt-5 sm:flex-row sm:items-start sm:justify-between"
            >
              <PostTags tags={post.tags} class="text-sm" title="Topics" />
              <SocialShare url={url} text={post.title} class="sm:justify-end" />
            </div>
          </div>

          {
            post.image ? (
              <div class="lg:pt-1">
                <div class="overflow-hidden rounded-[1.5rem] border border-white/10 bg-[var(--vipyr-bg-panel)] shadow-[var(--vipyr-shadow)]">
                  <Image
                    src={post.image}
                    class="w-full"
                    widths={[480, 720]}
                    sizes="(max-width: 1024px) 100vw, 340px"
                    alt={post?.excerpt || ''}
                    width={720}
                    height={540}
                    aspectRatio="4:3"
                    layout="cover"
                    loading="eager"
                    decoding="async"
                  />
                </div>
              </div>
            ) : null
          }
        </div>
      </div>
    </header>
    <div
      class="mx-auto mt-10 max-w-6xl px-5 sm:px-6 lg:mt-12 lg:grid lg:grid-cols-[minmax(0,1fr)_250px] lg:items-start lg:gap-12"
    >
      <div
        data-article-prose
        class="vipyr-prose-code prose prose-base prose-invert max-w-3xl px-0 prose-headings:text-slate-100 sm:px-0"
      >
        <slot />
      </div>
      <aside data-article-toc class="hidden self-start lg:block">
        <div class="sticky top-28 w-full max-w-[250px] max-h-[calc(100vh-8rem)] overflow-y-auto pr-1">
          <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-slate-500">On this page</div>
          <nav class="mt-4" aria-label="Table of contents">
            <ol data-article-toc-list class="space-y-1"></ol>
          </nav>
        </div>
      </aside>
    </div>
  </article>
</section>

<script is:inline>
  (() => {
    const selector = '[data-article-root]';

    const slugify = (value) =>
      value
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-');

    const setupToc = () => {
      const root = document.querySelector(selector);
      if (!(root instanceof HTMLElement)) return;

      const prose = root.querySelector('[data-article-prose]');
      const toc = root.querySelector('[data-article-toc]');
      const list = root.querySelector('[data-article-toc-list]');

      if (!(prose instanceof HTMLElement) || !(toc instanceof HTMLElement) || !(list instanceof HTMLElement)) return;

      const headings = Array.from(prose.querySelectorAll('h2, h3')).filter((heading) => heading.textContent?.trim());

      list.innerHTML = '';

      if (!headings.length) {
        toc.classList.add('hidden');
        return;
      }

      toc.classList.remove('hidden');

      const seenIds = new Set();

      headings.forEach((heading) => {
        if (!heading.id) {
          heading.id = slugify(heading.textContent || 'section');
        }

        let candidateId = heading.id;
        let counter = 2;
        while (seenIds.has(candidateId)) {
          candidateId = `${heading.id}-${counter}`;
          counter += 1;
        }

        if (candidateId !== heading.id) {
          heading.id = candidateId;
        }

        seenIds.add(heading.id);

        const item = document.createElement('li');
        const link = document.createElement('a');
        const level = heading.tagName.toLowerCase();

        link.href = `#${heading.id}`;
        link.textContent = heading.textContent || '';
        link.dataset.articleTocLink = heading.id;
        link.className = [
          'article-toc-link',
          'block border-l border-white/8 py-1.5 pl-3 text-[0.92rem] leading-5 text-slate-400 transition hover:border-sky-300/30 hover:text-white',
          level === 'h3' ? 'pl-5 text-[0.88rem] text-slate-500' : '',
        ]
          .filter(Boolean)
          .join(' ');

        item.append(link);
        list.append(item);
      });

      const links = Array.from(list.querySelectorAll('[data-article-toc-link]'));

      const setActive = (id) => {
        links.forEach((link) => {
          const isActive = link.getAttribute('data-article-toc-link') === id;
          link.classList.toggle('is-active', isActive);
          link.setAttribute('aria-current', isActive ? 'true' : 'false');
        });
      };

      let activeId = headings[0].id;
      setActive(activeId);

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

          if (visible.length) {
            activeId = visible[0].target.id;
            setActive(activeId);
            return;
          }

          const passed = [...headings].reverse().find((heading) => heading.getBoundingClientRect().top < 140);
          if (passed && passed.id !== activeId) {
            activeId = passed.id;
            setActive(activeId);
          }
        },
        {
          rootMargin: '-18% 0px -65% 0px',
          threshold: [0, 1],
        }
      );

      headings.forEach((heading) => observer.observe(heading));
    };

    if (!window.__vipyrArticleTocBound) {
      window.__vipyrArticleTocBound = true;
      window.addEventListener('load', setupToc);
      document.addEventListener('astro:page-load', setupToc);
      document.addEventListener('astro:after-swap', setupToc);
    }

    setupToc();
  })();
</script>
