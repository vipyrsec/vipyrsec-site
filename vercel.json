{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/a-gap-in-the-armor",
      "destination": "/research/a-gap-in-the-armor",
      "permanent": true
    },
    {
      "source": "/dependency-dilemma",
      "destination": "/research/dependency-dilemma",
      "permanent": true
    },
    {
      "source": "/dragonfly-client-internals",
      "destination": "/research/dragonfly-client-internals",
      "permanent": true
    },
    {
      "source": "/elf64-rat-malware",
      "destination": "/research/elf64-rat-malware",
      "permanent": true
    },
    {
      "source": "/nuisance-malware",
      "destination": "/research/nuisance-malware",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
