---
import { SITE, METADATA, I18N } from '~/config/site';
import type { MetaData, MetaDataImage, MetaDataOpenGraph, MetaDataTwitter } from '~/types';
import { getCanonical } from '~/utils/permalinks';

import { adaptOpenGraphImages } from '~/utils/images';

export interface Props extends MetaData {
  dontUseTitleTemplate?: boolean;
}

const {
  title,
  ignoreTitleTemplate = false,
  canonical = String(getCanonical(String(Astro.url.pathname))),
  robots = {},
  description,
  openGraph = {},
  twitter = {},
} = Astro.props;

const resolvedTitle = title ?? METADATA.title.default;
const titleTemplate = ignoreTitleTemplate ? '%s' : METADATA.title.template;
const pageTitle =
  resolvedTitle && titleTemplate.includes('%s') ? titleTemplate.replace('%s', resolvedTitle) : resolvedTitle;
const robotsContent = [
  typeof robots.index !== 'undefined'
    ? robots.index
      ? 'index'
      : 'noindex'
    : METADATA.robots?.index
      ? 'index'
      : 'noindex',
  typeof robots.follow !== 'undefined'
    ? robots.follow
      ? 'follow'
      : 'nofollow'
    : METADATA.robots?.follow
      ? 'follow'
      : 'nofollow',
].join(', ');
const resolvedDescription = description ?? METADATA.description;

const defaultOpenGraph: MetaDataOpenGraph = {
  url: canonical,
  siteName: SITE.name,
  images: [],
  locale: I18N.language,
  type: 'website',
};

const resolvedOpenGraph: MetaDataOpenGraph = {
  ...defaultOpenGraph,
  ...METADATA.openGraph,
  ...openGraph,
  url: canonical,
};

const resolvedOpenGraphImages = (await adaptOpenGraphImages(resolvedOpenGraph, Astro.site)).images ?? [];

const resolvedTwitter: MetaDataTwitter = {
  cardType: resolvedOpenGraphImages.length ? 'summary_large_image' : 'summary',
  ...METADATA.twitter,
  ...twitter,
};

const twitterTitle = resolvedTitle;
const twitterDescription = resolvedDescription;
---

<title>{pageTitle}</title>
<link rel="canonical" href={canonical} />
<meta name="robots" content={robotsContent} />

{resolvedDescription && <meta name="description" content={resolvedDescription} />}

<meta property="og:title" content={resolvedTitle} />
<meta property="og:type" content={resolvedOpenGraph.type ?? 'website'} />
<meta property="og:url" content={resolvedOpenGraph.url ?? canonical} />
<meta property="og:site_name" content={resolvedOpenGraph.siteName ?? SITE.name} />
{resolvedDescription && <meta property="og:description" content={resolvedDescription} />}
{resolvedOpenGraph.locale && <meta property="og:locale" content={resolvedOpenGraph.locale} />}
{
  resolvedOpenGraphImages.map((image: MetaDataImage) => (
    <>
      <meta property="og:image" content={image.url} />
      {image.width && <meta property="og:image:width" content={String(image.width)} />}
      {image.height && <meta property="og:image:height" content={String(image.height)} />}
    </>
  ))
}

{resolvedTwitter.cardType && <meta name="twitter:card" content={resolvedTwitter.cardType} />}
{resolvedTwitter.site && <meta name="twitter:site" content={resolvedTwitter.site} />}
{resolvedTwitter.handle && <meta name="twitter:creator" content={resolvedTwitter.handle} />}
{twitterTitle && <meta name="twitter:title" content={twitterTitle} />}
{twitterDescription && <meta name="twitter:description" content={twitterDescription} />}
{resolvedOpenGraphImages[0]?.url && <meta name="twitter:image" content={resolvedOpenGraphImages[0].url} />}
