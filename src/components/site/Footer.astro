---
import { Icon } from 'astro-icon/components';
import { SITE } from '~/config/site';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote = '', theme = 'light' } = Astro.props;
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative mt-24 border-t border-white/10 not-prose']}>
  <div
    class="absolute inset-0 pointer-events-none bg-[linear-gradient(180deg,rgba(14,23,47,0.18),rgba(6,12,26,0.88))]"
    aria-hidden="true"
  >
  </div>
  <div
    class="relative mx-auto max-w-7xl px-4 text-slate-300 sm:px-6 intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
  >
    <div class="grid grid-cols-12 gap-8 py-12 md:py-16">
      <div class="col-span-12 lg:col-span-5">
        <div class="mb-4">
          <a class="inline-block text-xl font-semibold tracking-tight text-white" href={getHomePermalink()}
            >{SITE?.name}</a
          >
        </div>
        <p class="max-w-md text-sm leading-7 text-slate-400">
          Calm operational security for the open source ecosystem. Vipyr Security publishes research, supports malware
          detection and takedown workflows, and helps make package ecosystems more resilient.
        </p>
        <div class="mt-4 flex gap-1 text-sm text-slate-500">
          {
            secondaryLinks.map(({ text, href }, index) => (
              <>
                {index !== 0 ? ' · ' : ''}
                <a
                  class="transition duration-150 ease-in-out hover:text-slate-200 hover:underline"
                  href={href}
                  set:html={text}
                />
              </>
            ))
          }
        </div>
      </div>
      {
        links.map(({ title, links }) => (
          <div class="col-span-6 md:col-span-3 lg:col-span-2">
            <div class="mb-3 text-xs font-semibold uppercase tracking-[0.28em] text-slate-500">{title}</div>
            {links && Array.isArray(links) && links.length > 0 && (
              <ul class="space-y-3 text-sm">
                {links.map(({ text, href, ariaLabel }) => (
                  <li>
                    <a
                      class="text-slate-300 transition duration-150 ease-in-out hover:text-white hover:underline"
                      href={href}
                      aria-label={ariaLabel}
                    >
                      <Fragment set:html={text} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>
    <div class="border-t border-white/10 py-6 md:flex md:items-center md:justify-between md:py-8">
      {
        socialLinks?.length ? (
          <ul class="mb-4 -ml-2 flex md:order-1 md:mb-0 md:ml-4 rtl:ml-0 rtl:-mr-2 rtl:md:ml-0 rtl:md:mr-4">
            {socialLinks.map(({ ariaLabel, href, text, icon }) => (
              <li>
                <a
                  class="inline-flex items-center rounded-full p-2.5 text-slate-400 transition hover:bg-white/[0.06] hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-300/50"
                  aria-label={ariaLabel}
                  href={href}
                >
                  {icon && <Icon name={icon} class="w-5 h-5" />}
                  <Fragment set:html={text} />
                </a>
              </li>
            ))}
          </ul>
        ) : (
          ''
        )
      }

      <div class="mr-4 text-sm text-slate-500">
        <Fragment set:html={footNote} />
      </div>
    </div>
  </div>
</footer>
