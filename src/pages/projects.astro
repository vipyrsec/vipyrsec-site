---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';
import Button from '~/components/ui/Button.astro';
import SectionHeading from '~/components/site/SectionHeading.astro';

const metadata = {
  title: 'Projects',
  description:
    'Explore Dragonfly and the core tooling Vipyr Security uses to support package ecosystem analysis and response.',
};

const projects = [
  {
    title: 'Dragonfly Server',
    description:
      'A FastAPI-based aggregation and job distribution service that coordinates workload flow and analysis intake across the broader Dragonfly workflow.',
    role: 'Distribution and orchestration',
    stack: 'FastAPI, Python',
    href: 'https://github.com/vipyrsec/dragonfly-mainframe',
    icon: 'tabler:server-2',
  },
  {
    title: 'Dragonfly Client',
    description:
      'A Rust scanner designed to safely process potentially malicious files and apply detection logic quickly across large package streams.',
    role: 'Scanning and enrichment',
    stack: 'Rust',
    href: 'https://github.com/vipyrsec/dragonfly-client-rs',
    icon: 'tabler:cpu',
  },
  {
    title: 'Dragonfly Bot',
    description:
      'A Discord interface that keeps community-assisted triage close to the underlying operational workflow instead of separating collaboration from action.',
    role: 'Triage interface',
    stack: 'Discord integrations',
    href: 'https://github.com/vipyrsec/bot',
    icon: 'tabler:brand-discord',
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-7xl px-4 pb-18 pt-10 sm:px-6 md:pb-24 md:pt-16">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(360px,0.9fr)] lg:items-start">
      <div class="max-w-3xl">
        <div
          class="mb-5 inline-flex rounded-full border border-sky-400/20 bg-sky-400/10 px-3 py-1 text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-sky-200"
        >
          Projects
        </div>
        <h1 class="text-5xl font-semibold tracking-[-0.06em] text-white sm:text-6xl">
          Dragonfly is the operational tooling layer behind the research and response work.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-400">
          The project portfolio should read like a coherent security workflow, not a disconnected list of repositories.
          Dragonfly brings scanning, aggregation, and collaboration into one operating model.
        </p>
      </div>

      <div class="rounded-[2rem] border border-white/10 bg-[var(--vipyr-bg-elevated)] p-6 shadow-[var(--vipyr-shadow)]">
        <div class="text-[0.72rem] font-semibold uppercase tracking-[0.3em] text-slate-500">System view</div>
        <div class="mt-6 space-y-3">
          <div
            class="flex items-center justify-between rounded-full border border-white/8 bg-[var(--vipyr-bg-panel)] px-4 py-3 text-sm"
          >
            <span class="font-medium text-slate-200">Ingest package jobs</span>
            <span class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-slate-500">Server</span>
          </div>
          <div
            class="flex items-center justify-between rounded-full border border-white/8 bg-[var(--vipyr-bg-panel)] px-4 py-3 text-sm"
          >
            <span class="font-medium text-slate-200">Scan and enrich results</span>
            <span class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-slate-500">Client</span>
          </div>
          <div
            class="flex items-center justify-between rounded-full border border-white/8 bg-[var(--vipyr-bg-panel)] px-4 py-3 text-sm"
          >
            <span class="font-medium text-slate-200">Coordinate community triage</span>
            <span class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-slate-500">Bot</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-18 sm:px-6 md:py-24">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-start">
      <SectionHeading
        eyebrow="Platform framing"
        title="A distributed computing approach to package ecosystem threat detection."
        description="Each Dragonfly component exists to support one stage of the workflow, but the real value is in how the pieces operate together."
      />
      <div class="grid gap-4">
        {
          projects.map((project) => (
            <div class="rounded-[1.75rem] border border-white/10 bg-[var(--vipyr-bg-panel)] p-6 shadow-[var(--vipyr-shadow)]">
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-sky-400/20 bg-sky-400/10 text-sky-200">
                  <Icon name={project.icon} class="h-6 w-6" />
                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
                    <h2 class="text-xl font-semibold text-white">{project.title}</h2>
                    <div class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-slate-500">
                      {project.role}
                    </div>
                  </div>
                  <p class="mt-3 text-base leading-8 text-slate-400">{project.description}</p>
                  <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div class="text-sm text-slate-500">{project.stack}</div>
                    <Button variant="secondary" href={project.href} text="View source" icon="tabler:arrow-up-right" />
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-12 pt-18 sm:px-6 md:pb-20 md:pt-24">
    <div
      class="rounded-[2rem] border border-white/10 bg-[linear-gradient(135deg,rgba(21,38,79,0.94),rgba(8,16,34,0.94))] p-8 shadow-[var(--vipyr-shadow)] md:p-10"
    >
      <SectionHeading
        eyebrow="Next layer"
        title="Additional tools can expand from this system without breaking the page."
        description="The redesign keeps room for future scanners, utilities, and supporting services while keeping Dragonfly as the clearest story today."
      />
    </div>
  </section>
</Layout>
