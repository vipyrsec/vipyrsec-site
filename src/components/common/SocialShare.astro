---
import { Icon } from 'astro-icon/components';

export interface Props {
  text: string;
  url: string | URL;
  class?: string;
}

const { text, url, class: className = 'inline-block' } = Astro.props;
---

<div class:list={['flex flex-wrap items-center gap-2', className]}>
  <span class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-slate-500">Share</span>
  <button
    class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-slate-400 transition hover:border-white/20 hover:bg-white/[0.07] hover:text-white"
    title="Twitter Share"
    data-aw-social-share="twitter"
    data-aw-url={url}
    data-aw-text={text}
    ><Icon name="tabler:brand-x" class="h-5 w-5" />
  </button>
  <button
    class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-slate-400 transition hover:border-white/20 hover:bg-white/[0.07] hover:text-white"
    title="Facebook Share"
    data-aw-social-share="facebook"
    data-aw-url={url}
    ><Icon name="tabler:brand-facebook" class="h-5 w-5" />
  </button>
  <button
    class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-slate-400 transition hover:border-white/20 hover:bg-white/[0.07] hover:text-white"
    title="Linkedin Share"
    data-aw-social-share="linkedin"
    data-aw-url={url}
    data-aw-text={text}
    ><Icon name="tabler:brand-linkedin" class="h-5 w-5" />
  </button>
  <button
    class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-slate-400 transition hover:border-white/20 hover:bg-white/[0.07] hover:text-white"
    title="Whatsapp Share"
    data-aw-social-share="whatsapp"
    data-aw-url={url}
    data-aw-text={text}
    ><Icon name="tabler:brand-whatsapp" class="h-5 w-5" />
  </button>
  <button
    class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-slate-400 transition hover:border-white/20 hover:bg-white/[0.07] hover:text-white"
    title="Email Share"
    data-aw-social-share="mail"
    data-aw-url={url}
    data-aw-text={text}
    ><Icon name="tabler:mail" class="h-5 w-5" />
  </button>
</div>
