---
import { Icon } from 'astro-icon/components';
import { getBlogPermalink } from '~/utils/permalinks';
import { I18N } from '~/config/site';
import Button from '~/components/ui/Button.astro';

const { textDirection } = I18N;
---

<div class="mx-auto max-w-3xl px-6 pb-12 pt-8 sm:px-6 md:pb-20 md:pt-4">
  <Button variant="tertiary" class="px-4" href={getBlogPermalink()}>
    {
      textDirection === 'rtl' ? (
        <Icon name="tabler:chevron-right" class="h-5 w-5" />
      ) : (
        <Icon name="tabler:chevron-left" class="h-5 w-5" />
      )
    } Back to research
  </Button>
</div>
