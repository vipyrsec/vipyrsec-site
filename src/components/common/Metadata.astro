---
import { AstroSeo } from '@astrolib/seo';

import type { Props as AstroSeoProps } from '@astrolib/seo';

import { SITE, METADATA, I18N } from '~/config/site';
import type { MetaData } from '~/types';
import { getCanonical } from '~/utils/permalinks';

import { adaptOpenGraphImages } from '~/utils/images';

export interface Props extends MetaData {
  dontUseTitleTemplate?: boolean;
}

const {
  title,
  ignoreTitleTemplate = false,
  canonical = String(getCanonical(String(Astro.url.pathname))),
  robots = {},
  description,
  openGraph = {},
  twitter = {},
} = Astro.props;

const defaultOpenGraph = {
  url: canonical,
  site_name: SITE.name,
  images: [],
  locale: I18N.language,
  type: 'website',
};

const metadataOpenGraph = {
  ...METADATA.openGraph,
  site_name: METADATA.openGraph?.siteName,
};

const seoProps: AstroSeoProps = {
  title: title ?? METADATA.title.default,
  titleTemplate: ignoreTitleTemplate ? '%s' : METADATA.title.template,
  canonical,
  noindex: typeof robots.index !== 'undefined' ? !robots.index : !METADATA.robots?.index,
  nofollow: typeof robots.follow !== 'undefined' ? !robots.follow : !METADATA.robots?.follow,
  description: description ?? METADATA.description,
  openGraph: {
    ...defaultOpenGraph,
    ...metadataOpenGraph,
    ...openGraph,
    url: canonical,
  },
  twitter: {
    cardType: openGraph?.images?.length ? 'summary_large_image' : 'summary',
    ...METADATA.twitter,
    ...twitter,
  },
};
---

<AstroSeo {...{ ...seoProps, openGraph: await adaptOpenGraphImages(seoProps?.openGraph, Astro.site) }} />
