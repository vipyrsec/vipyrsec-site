---
const {
  title = await Astro.slots.render('default'),
  subtitle = await Astro.slots.render('subtitle'),
  eyebrow,
} = Astro.props;
---

<header class="mx-auto mb-10 max-w-3xl text-center md:mb-16">
  {
    eyebrow && (
      <div class="mx-auto mb-4 inline-flex rounded-full border border-sky-400/20 bg-sky-400/10 px-3 py-1 text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-sky-200">
        {eyebrow}
      </div>
    )
  }
  <h1 class="text-4xl font-semibold tracking-[-0.05em] text-white md:text-6xl" set:html={title} />
  {
    subtitle && (
      <div class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-slate-400 md:mt-5 md:text-xl" set:html={subtitle} />
    )
  }
</header>
