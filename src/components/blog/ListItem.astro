---
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';
import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';

import { APP_BLOG } from '~/config/site';
import type { Post } from '~/types';

import { getPermalink } from '~/utils/permalinks';
import { findImage } from '~/utils/images';
import { getFormattedDate } from '~/utils/utils';

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const image = (await findImage(post.image)) as ImageMetadata | undefined;

const link = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';
---

<article
  class={`mx-auto grid max-w-md gap-5 rounded-[1.5rem] border border-white/10 bg-white/[0.03] p-4 shadow-[var(--vipyr-shadow)] intersect-once intersect-quarter transition hover:border-white/16 hover:bg-white/[0.05] motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade md:max-w-none md:gap-6 ${image ? 'md:grid-cols-[220px_minmax(0,1fr)]' : ''}`}
>
  {
    image &&
      (link ? (
        <a class="relative block group" href={link ?? 'javascript:void(0)'}>
          <div class="relative h-0 overflow-hidden rounded-[1.125rem] border border-white/8 bg-gray-400 pb-[62%] dark:bg-slate-700 md:h-full md:min-h-[168px] md:pb-0">
            {image && (
              <Image
                src={image}
                class="absolute inset-0 h-full w-full rounded bg-gray-400 object-cover transition duration-500 group-hover:scale-[1.03] dark:bg-slate-700"
                widths={[400, 900]}
                width={900}
                sizes="(max-width: 900px) 400px, 900px"
                alt={post.title}
                aspectRatio="16:9"
                loading="lazy"
                decoding="async"
              />
            )}
          </div>
        </a>
      ) : (
        <div class="relative h-0 overflow-hidden rounded-[1.125rem] border border-white/8 bg-gray-400 pb-[62%] dark:bg-slate-700 md:h-full md:min-h-[168px] md:pb-0">
          {image && (
            <Image
              src={image}
              class="absolute inset-0 h-full w-full rounded bg-gray-400 object-cover dark:bg-slate-700"
              widths={[400, 900]}
              width={900}
              sizes="(max-width: 900px) 400px, 900px"
              alt={post.title}
              aspectRatio="16:9"
              loading="lazy"
              decoding="async"
            />
          )}
        </div>
      ))
  }
  <div class="mt-1">
    <header>
      <div class="mb-3">
        <span class="text-[0.82rem] text-slate-500">
          <Icon name="tabler:clock" class="inline-block h-3.5 w-3.5 -mt-0.5" />
          <time datetime={String(post.publishDate)} class="inline-block">{getFormattedDate(post.publishDate)}</time>
          {
            post.author && (
              <>
                {' '}
                · <Icon name="tabler:user" class="inline-block h-3.5 w-3.5 -mt-0.5" />
                <span>{post.author.replaceAll('-', ' ')}</span>
              </>
            )
          }
          {
            post.category && (
              <>
                {' '}
                ·{' '}
                <a
                  class="transition hover:text-slate-200 hover:underline"
                  href={getPermalink(post.category.slug, 'category')}
                >
                  {post.category.title}
                </a>
              </>
            )
          }
        </span>
      </div>
      <h2 class="mb-3 text-xl font-semibold leading-tight text-white sm:text-[1.7rem]">
        {
          link ? (
            <a class="inline-block transition ease-in duration-200 hover:text-sky-200" href={link}>
              {post.title}
            </a>
          ) : (
            post.title
          )
        }
      </h2>
    </header>

    {post.excerpt && <p class="flex-grow text-sm leading-7 text-slate-400 sm:text-[0.98rem]">{post.excerpt}</p>}
    {
      post.tags && Array.isArray(post.tags) ? (
        <footer class="mt-4">
          <PostTags tags={post.tags} class="text-sm" />
        </footer>
      ) : (
        <Fragment />
      )
    }
  </div>
</article>
